+/// Single-threaded sort for environments without thread support (WASI).
+/// Reads all input into memory, sorts, and outputs.
+#[cfg(target_os = "wasi")]
+fn exec_single_threaded(
+    files: &mut [OsString],
+    settings: &GlobalSettings,
+    output: Output,
+) -> UResult<()> {
+    use std::io::Read;
+    use std::ops::Range;
+    use itertools::Itertools;
+    use crate::chunks::{self, Chunk, ChunkContents, LineData};
+
+    let separator: u8 = settings.line_ending.into();
+
+    // Read all input into a single buffer.
+    let mut all_data = Vec::new();
+    for file in files.iter() {
+        let mut f = open(file)?;
+        f.read_to_end(&mut all_data).map_err(|e| {
+            SortError::ReadFailed { path: file.clone().into(), error: e }
+        })?;
+    }
+
+    // Build a Chunk with parsed lines.
+    let mut chunk = Chunk::try_new(all_data, |buffer: &Vec<u8>| -> Result<ChunkContents<'_>, std::io::Error> {
+        let mut lines = Vec::new();
+        let mut line_data = LineData {
+            selections: Vec::new(),
+            num_infos: Vec::new(),
+            parsed_floats: Vec::new(),
+            line_num_floats: Vec::new(),
+        };
+        let mut token_buffer: Vec<Range<usize>> = Vec::new();
+        let mut line_count_hint: usize = 0;
+        chunks::parse_lines(
+            buffer.as_slice(),
+            &mut lines,
+            &mut line_data,
+            &mut token_buffer,
+            &mut line_count_hint,
+            separator,
+            settings,
+        );
+        Ok(ChunkContents {
+            lines,
+            line_data,
+            token_buffer,
+            line_count_hint,
+        })
+    }).map_err(|e| std::io::Error::new(std::io::ErrorKind::Other, e.to_string()))?;
+
+    // Check mode: verify the input is already sorted.
+    if settings.check {
+        let max_allowed_cmp = if settings.unique {
+            std::cmp::Ordering::Less
+        } else {
+            std::cmp::Ordering::Equal
+        };
+        for (i, pair) in chunk.lines().windows(2).enumerate() {
+            let cmp = compare_by(&pair[0], &pair[1], settings, chunk.line_data(), chunk.line_data());
+            if cmp == std::cmp::Ordering::Greater
+                || (cmp == std::cmp::Ordering::Equal && max_allowed_cmp == std::cmp::Ordering::Less)
+            {
+                return Err(SortError::Disorder {
+                    file: files.first().cloned().unwrap_or_default(),
+                    line_number: i + 2,
+                    line: std::str::from_utf8(pair[1].line).unwrap_or("").to_string(),
+                    silent: settings.check_silent,
+                }.into());
+            }
+        }
+        return Ok(());
+    }
+
+    // Sort in place.
+    chunk.with_dependent_mut(|_, contents| {
+        sort_by(&mut contents.lines, settings, &contents.line_data);
+    });
+
+    // Output.
+    if settings.unique {
+        print_sorted(
+            chunk.lines().iter().dedup_by(|a, b| {
+                compare_by(a, b, settings, chunk.line_data(), chunk.line_data()) == std::cmp::Ordering::Equal
+            }),
+            settings,
+            output,
+        )
     } else {
-        let mut lines = files.iter().map(open);
-        ext_sort(&mut lines, settings, output, tmp_dir)
+        print_sorted(chunk.lines().iter(), settings, output)
     }
 }
 
