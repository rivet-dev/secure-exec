+// wasmVM: WASI compatibility — MetadataExt lacks mode(), Permissions lacks from_mode()
+#[cfg(target_os = "wasi")]
+mod wasi_compat {
+    use std::fs;
+
+    /// Extension trait to provide mode() on WASI Metadata via host_fs.
+    pub trait MetadataMode {
+        fn mode(&self) -> u32;
+    }
+    impl MetadataMode for fs::Metadata {
+        fn mode(&self) -> u32 {
+            // Permissions wraps FilePermissions { mode: u32 }. Extract via transmute.
+            let perms = self.permissions();
+            const _: () = assert!(std::mem::size_of::<fs::Permissions>() == std::mem::size_of::<u32>());
+            unsafe { std::mem::transmute(perms) }
+        }
+    }
+
+    /// Set POSIX-style permissions on a file using host_fs::chmod on WASI.
+    pub fn set_permissions_from_mode(path: &std::path::Path, mode: u32) -> std::io::Result<()> {
+        // Permissions wraps FilePermissions { mode: u32 }. Since PermissionsExt
+        // is not available on WASI, construct via transmute (layout is just u32).
+        const _: () = assert!(std::mem::size_of::<fs::Permissions>() == std::mem::size_of::<u32>());
+        let perms: fs::Permissions = unsafe { std::mem::transmute(mode) };
+        fs::set_permissions(path, perms)
+    }
+}
+#[cfg(target_os = "wasi")]
+use wasi_compat::MetadataMode;
