{
	"name": "nanosandbox",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@8.15.6",
	"scripts": {
		"build": "turbo run build",
		"check-types": "turbo run check-types",
		"test": "turbo run test",
		"test:watch": "turbo run test:watch",
		"dev": "turbo run dev",
		"shell": "pnpm build -F nanosandbox && pnpm --filter @nanosandbox/terminal start",
		"lint": "biome check",
		"lint:fix": "biome check --write"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.10",
		"@types/node": "^25.0.3",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"turbo": "^2.6.3",
		"typescript": "^5.9.3",
		"vitest": "^4.0.16"
	}
}
