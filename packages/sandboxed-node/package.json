{
  "name": "sandboxed-node",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "build:bridge": "esbuild bridge/index.ts --bundle --format=iife --global-name=bridge --outfile=assets/bridge.js",
    "build": "pnpm run build:bridge && tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "esbuild": "^0.27.2",
    "isolated-vm": "^6.0.2",
    "node-stdlib-browser": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@wasmer/sdk": "^0.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
