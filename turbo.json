{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build:bridge": {
      "outputs": ["dist/bridge.js"]
    },
    "build:isolate-runtime": {
      "outputs": ["dist/isolate-runtime/**", "src/generated/isolate-runtime.ts"]
    },
    "build": {
      "dependsOn": ["^build", "build:bridge", "build:isolate-runtime"],
      "outputs": ["dist/**"]
    },
    "check-types": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
