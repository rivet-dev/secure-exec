Implement kill() via host_process WASM import.

Un-ifdefs kill() declaration from signal.h (was hidden behind
__wasilibc_unmodified_upstream) and provides an implementation
that calls host_process.proc_kill. Other signal functions
(sigemptyset, sigaction, etc.) remain hidden.

Import signature matches wasmvm/crates/wasi-ext/src/lib.rs exactly.

--- a/libc-top-half/musl/include/signal.h
+++ b/libc-top-half/musl/include/signal.h
@@ -220,11 +220,11 @@
 #define SIGRTMAX  (__libc_current_sigrtmax())
 #endif

-#ifdef __wasilibc_unmodified_upstream /* WASI has no signals */
 int kill(pid_t, int);

+#ifdef __wasilibc_unmodified_upstream /* WASI has no signal sets */
 int sigemptyset(sigset_t *);
 int sigfillset(sigset_t *);
 int sigaddset(sigset_t *, int);
 int sigdelset(sigset_t *, int);
 int sigismember(const sigset_t *, int);

--- /dev/null
+++ b/libc-bottom-half/sources/host_kill.c
@@ -0,0 +1,25 @@
+// kill() via wasmVM host_process import.
+//
+// Replaces wasi-libc's hidden kill() declaration with an implementation
+// that calls our custom host_process.proc_kill WASM import.
+//
+// Import signature matches wasmvm/crates/wasi-ext/src/lib.rs exactly.
+
+#include <errno.h>
+#include <stdint.h>
+#include <signal.h>
+
+#define WASM_IMPORT(mod, fn) \
+    __attribute__((__import_module__(mod), __import_name__(fn)))
+
+// host_process.proc_kill(pid: u32, signal: u32) -> errno
+WASM_IMPORT("host_process", "proc_kill")
+uint32_t __host_proc_kill(uint32_t pid, uint32_t signal);
+
+int kill(pid_t pid, int sig) {
+    uint32_t err = __host_proc_kill((uint32_t)pid, (uint32_t)sig);
+    if (err != 0) {
+        errno = (int)err;
+        return -1;
+    }
+    return 0;
+}
